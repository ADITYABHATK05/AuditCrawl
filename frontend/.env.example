# Frontend Environment Configuration

# Optional: Specify the backend API URL explicitly
# If not set, the frontend will auto-detect based on the current hostname
# Use this if your backend is on a different machine/port
# VITE_API_BASE=http://192.168.1.100:8000/api

# Optional: Backend port (used for auto-detection if VITE_API_BASE is not set)
# Default: 8000
# VITE_BACKEND_PORT=8000

# Optional: Frontend dev server port
# Default: 5173
# VITE_PORT=5173
