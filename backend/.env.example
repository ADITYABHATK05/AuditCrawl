# Backend Environment Configuration

# Optional: Gemini API key for AI-powered features
# GEMINI_API_KEY=your_api_key_here

# Optional: Allowed CORS origins (comma-separated)
# If not set, defaults include localhost:5173, localhost:3000, etc.
# For production or remote setups, specify your frontend URL(s)
# ALLOWED_ORIGINS=http://localhost:5173,http://frontend-machine:5173,http://192.168.1.100:5173

# Optional: Backend URL (for reference, not used by backend itself)
# BACKEND_URL=http://localhost:8000

# Optional: Frontend URL used in email "View dashboard" link
# FRONTEND_URL=http://localhost:5173

# SMTP settings for scan completion emails
# Example for Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=yourgmail@gmail.com
# SMTP_PASSWORD=your_16_char_app_password
# SMTP_FROM=yourgmail@gmail.com
# SMTP_STARTTLS=true
