<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>AuditCrawl Report</title>
  <style>
    :root {
      --bg: #f5f7f9;
      --card: #ffffff;
      --text: #102a43;
      --muted: #486581;
      --high: #b42318;
      --medium: #b54708;
      --low: #0369a1;
      --accent: #0f766e;
    }
    body { font-family: "Segoe UI", Tahoma, sans-serif; margin: 0; padding: 24px; background: linear-gradient(180deg, #eef6f8, var(--bg)); color: var(--text); }
    h1, h2 { margin: 0 0 12px 0; }
    .note { background: #fff8db; border-left: 4px solid #f59e0b; padding: 10px 12px; margin-bottom: 18px; }
    .grid { display: grid; gap: 12px; }
    .card { background: var(--card); border-radius: 10px; padding: 14px; box-shadow: 0 2px 8px rgba(0,0,0,.06); }
    .risk-high { color: var(--high); font-weight: 700; }
    .risk-medium { color: var(--medium); font-weight: 700; }
    .risk-low { color: var(--low); font-weight: 700; }
    code { background: #f1f5f9; padding: 2px 4px; border-radius: 4px; }
    pre { white-space: pre-wrap; background: #f8fafc; padding: 10px; border-radius: 6px; }
  </style>
</head>
<body>
  <h1>AuditCrawl Security Scan Report</h1>
  <p>Generated for educational, authorized security testing only.</p>
  <div class="note">This POC is for educational use; do not run on real systems without permission.</div>

  <h2>Findings ({{ findings|length }})</h2>
  <section class="grid">
    {% for f in findings %}
    <article class="card">
      <h3>{{ f.vulnerability }}</h3>
      <p>
        Risk:
        <span class="risk-{{ f.risk|lower }}">{{ f.risk }}</span>
      </p>
      <p><strong>Endpoint:</strong> <code>{{ f.endpoint }}</code></p>
      <p><strong>Method:</strong> {{ f.method }}</p>
      <p><strong>Parameter:</strong> {{ f.parameter or "N/A" }}</p>
      <p><strong>Evidence:</strong> {{ f.evidence }}</p>
      <p><strong>Remediation:</strong> {{ f.remediation }}</p>
      {% if f.payload %}<p><strong>Payload:</strong> <code>{{ f.payload }}</code></p>{% endif %}
    </article>
    {% endfor %}
  </section>

  <h2>Safe PoCs</h2>
  <section class="grid">
    {% for p in pocs %}
    <article class="card">
      <h3>{{ p.vulnerability }}</h3>
      <p><strong>Endpoint:</strong> <code>{{ p.endpoint }}</code></p>
      <p><strong>Payload:</strong> <code>{{ p.payload }}</code></p>
      <pre>{{ p.reproduction_steps }}</pre>
    </article>
    {% endfor %}
  </section>
</body>
</html>
